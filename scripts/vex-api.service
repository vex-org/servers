[Unit]
Description=Vex API Server
After=network.target ollama.service

[Service]
Type=simple
User=vex
Group=vex
WorkingDirectory=/opt/vex-api
ExecStartPre=-+/opt/vex-api/scripts/vex-update.sh
ExecStart=/opt/vex-api/vex-api
Restart=always
RestartSec=5

# Environment (ignore if missing)
EnvironmentFile=-/opt/vex-api/.env
# vex-update.sh installs the compiler to /home/vex/.vex/bin/vex
# and symlinks /usr/local/bin/vex; keep this aligned with VEX_HOME in vex-update.service
Environment=VEX_BINARY=/home/vex/.vex/bin/vex
# LLVM location for AOT compilation — Ubuntu 24.04 installs to /usr/lib/llvm-22
Environment=LLVM_SYS_221_PREFIX=/usr/lib/llvm-22

# Resource limits
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
